{
  "$comment": "Tracked-file manifest for repo-template-audit. All keys except `repo_flavor` are canonical and must match the base template byte-for-byte. `repo_flavor` is per-repo: it declares which flavor's file lists this repo follows. The audit ignores `repo_flavor` when diffing manifest.json against canonical.",
  "version": 1,
  "repo_flavor": "base",
  "flavors": {
    "base": {
      "template_repo": "richwklein/repo-template-base",
      "exact_match": [
        ".editorconfig",
        ".gitattributes",
        ".github/CODEOWNERS",
        ".github/PULL_REQUEST_TEMPLATE.md",
        ".github/dependabot.yml",
        ".github/ISSUE_TEMPLATE/config.yaml",
        ".github/ISSUE_TEMPLATE/01-idea.yaml",
        ".github/ISSUE_TEMPLATE/02-bug.yaml",
        ".github/ISSUE_TEMPLATE/03-enhancement.yaml",
        ".github/ISSUE_TEMPLATE/04-task.yaml",
        ".github/workflows/code-codeql.yaml",
        ".vscode/extensions.json",
        ".vscode/settings.json",
        "docs/BRANCH_PROTECTION.md",
        "docs/REPO_SETTINGS.yaml",
        "AGENTS.md",
        "CONTRIBUTING.md",
        "SECURITY.md",
        "LICENSE",
        ".claude/skills/repo-template-audit/SKILL.md",
        ".claude/skills/repo-template-audit/manifest.json",
        ".claude/skills/repo-template-audit/lib/audit.py"
      ],
      "presence_only": ["CODE_OF_CONDUCT.md"],
      "schema_match": []
    },
    "astro": {
      "template_repo": "richwklein/repo-template-astro",
      "$comment": "Paths here override base.exact_match when auditing an astro-flavor repo. The astro template owns the canonical version of these files.",
      "exact_match": [
        ".tool-versions",
        "eslint.config.mjs",
        "prettier.config.mjs",
        "tsconfig.json",
        "vitest.config.ts",
        ".github/actions/setup-tools/action.yaml",
        ".github/workflows/code-lint.yaml",
        ".github/workflows/code-test.yaml",
        ".github/workflows/code-build.yaml",
        ".github/workflows/report-coverage.yaml",
        ".github/workflows/release-please.yaml",
        ".github/workflows/code-codeql.yaml",
        ".github/dependabot.yml",
        ".vscode/extensions.json",
        ".vscode/settings.json",
        ".gitignore",
        "AGENTS.md"
      ],
      "presence_only": [
        "package.json",
        "package-lock.json",
        "astro.config.ts",
        "vitest.setup.ts",
        "release-please-config.json",
        ".release-please-manifest.json"
      ],
      "schema_match": [
        {
          "path": "package.json",
          "required_scripts": [
            "dev",
            "build",
            "preview",
            "lint",
            "lint:fix",
            "format",
            "format:fix",
            "test",
            "test:coverage",
            "verify"
          ]
        }
      ]
    }
  },
  "settings_manifest_path": "docs/REPO_SETTINGS.yaml"
}
