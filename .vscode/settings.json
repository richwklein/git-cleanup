{
  "files.exclude": {
    ".git/": true
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "editor.tabCompletion": "on",
  "editor.rulers": [80, 100, 120],
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.wordWrap": "wordWrapColumn",
  "cSpell.words": ["codeql", "richwklein"],
  "[markdown]": {
    "editor.wordWrap": "wordWrapColumn"
  }
}
